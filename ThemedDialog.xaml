<Window x:Class="MarkdownPad.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sh="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight" MaxWidth="480"
        Background="{DynamicResource PanelBg}"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        WindowStartupLocation="CenterOwner">

  <!-- WindowChrome keeps the window borderless but natively composited (crisp on
       high-DPI) instead of a blurry layered/transparent window. -->
  <sh:WindowChrome.WindowChrome>
    <sh:WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" ResizeBorderThickness="0"/>
  </sh:WindowChrome.WindowChrome>

  <Window.Resources>
    <Style x:Key="DlgPrimary" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource AccentFg}"/>
      <Setter Property="Background" Value="{DynamicResource Accent}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6" Padding="18,8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Opacity" Value="0.88"/></Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Opacity" Value="0.75"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DlgNormal" TargetType="Button">
      <Setter Property="Foreground" Value="{DynamicResource AppFg}"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="SnapsToDevicePixels" Value="True"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6" Padding="18,8"
                    BorderBrush="{DynamicResource Border}" BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource Hover}"/></Trigger>
              <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource Border}"/></Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource Border}" BorderThickness="1">
    <Grid Margin="26,22,26,20" MinWidth="360">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
        <Border x:Name="AccentDot" Width="10" Height="10" CornerRadius="5"
                Background="{DynamicResource Accent}" VerticalAlignment="Center" Margin="0,0,10,0"/>
        <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppFg}" VerticalAlignment="Center"/>
      </StackPanel>

      <TextBlock x:Name="MessageText" Grid.Row="1" FontSize="13" TextWrapping="Wrap"
                 Foreground="{DynamicResource AppFg}" Margin="0,0,0,22" Opacity="0.92"/>

      <StackPanel x:Name="ButtonRow" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"/>
    </Grid>
  </Border>
</Window>
